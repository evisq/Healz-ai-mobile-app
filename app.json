{
  "expo": {
    "name": "Healz Mobile",
    "slug": "healz-ai-mobile-app",
    "version": "1.0.0",
    "scheme": "healz-mobile",
    "orientation": "portrait",
    "icon": "./assets/healz-heart.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.evisq.healzaimobile",
      "supportsTablet": true
    },
    "android": {
      "package": "com.evisq.healzaimobile",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#FFF4F8",
        "foregroundImage": "./assets/healz-heart.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/healz-heart.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFF8FA",
          "image": "./assets/splash-transparent.png",
          "imageWidth": 1,
          "resizeMode": "contain",
          "dark": {
            "backgroundColor": "#181416",
            "image": "./assets/splash-transparent.png"
          }
        }
      ],
      [
        "expo-share-intent",
        {
          "androidIntentFilters": [
            "application/pdf",
            "image/*"
          ],
          "androidMultiIntentFilters": [
            "application/pdf",
            "image/*"
          ],
          "iosAppGroupIdentifier": "group.com.evisq.healzaimobile",
          "iosActivationRules": {
            "NSExtensionActivationSupportsFileWithMaxCount": 5,
            "NSExtensionActivationSupportsImageWithMaxCount": 5
          },
          "iosShareExtensionBundleIdentifier": "com.evisq.healzaimobile.ShareExtension"
        }
      ]
    ]
  }
}
